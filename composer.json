{
    "name": "explicatis/ns-protect-site",
    "type": "typo3-cms-extension",
    "description": "This extension will help you to quickly password protected TYPO3 pages without frontend users management, check manual for more details.",
    "homepage": "https://extensions.typo3.org/extension/ns_protect_site/",
    "license": "GPL-2.0+",
    "keywords": [
        "TYPO3 CMS",
        "Protect",
        "Page",
        "Site",
        "Password"
    ],
    "authors": [
        {
          "name": "NITSAN Technologies",
          "role": "Developer",
          "homepage": "https://www.nitsan.in/"
        },
        {
          "name": "Explicatis GmbH",
            "role": "Developer",
            "homepage": "https://www.explicatis.com/"
        }
    ],
    "require": {
       "php": "^8.2",
       "typo3/cms-core": "^12.4 || ^13.4"
    },
    "autoload": {
        "psr-4": {
            "Nitsan\\NsProtectSite\\": "Classes"
        }
    },    
    "replace": {
        "typo3-ter/ns-protect-site": "self.version"
    },
    "extra": {
	 "typo3/cms": {
		"extension-key": "ns_protect_site"
	 }
    }
}
